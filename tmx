#!/usr/bin/env sh
# tmx: pick or create a tmux session via fzf, then attach/switch.
# author: Stephen McGurrin, 2026
# deps: tmux, fzf
# license: MIT

# ─── Globals (set early — used by both dispatch helpers and main) ───
TMUX_BIN="$(command -v tmux)"
HIDDEN_FILE="${HOME}/.tmx-hidden-sessions"
NOTES_FILE="${HOME}/.tmx-session-notes"

# Resolve script to absolute path for reliable fzf bind callbacks
case "$0" in
  /*) SCRIPT="$0" ;;
  */*) SCRIPT="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")" ;;
  *)   SCRIPT="$(command -v "$0")" ;;
esac

# ─── Helper functions ──────────────────────────────────────────

clean_sel() { printf '%s' "$1" | sed 's/\x1b\[[0-9;]*m//g; s/^[[:space:]]*//; s/[[:space:]]*[0-9]*w.*$//; s/^[●*] //; s/^ *//'; }

skip_header() {
  case "$1" in *━━━*|'') return 1 ;; esac
  return 0
}

# Print every hidden session (one per line); empty if no hidden file.
load_hidden_sessions() {
  [ -f "$HIDDEN_FILE" ] && cat "$HIDDEN_FILE" || true
}

# Return 0 (success) if $1 is in the hidden list.
is_hidden() {
  session="$1"
  hidden_sessions="$(load_hidden_sessions)"
  printf '%s\n' "$hidden_sessions" | grep -Fx "$session" >/dev/null 2>&1
}

# Toggle $1 in/out of the hidden file.
toggle_hidden() {
  session="$1"
  if is_hidden "$session"; then
    if [ -f "$HIDDEN_FILE" ]; then
      grep -Fxv "$session" "$HIDDEN_FILE" > "${HIDDEN_FILE}.tmp" 2>/dev/null || true
      mv "${HIDDEN_FILE}.tmp" "$HIDDEN_FILE"
    fi
  else
    printf '%s\n' "$session" >> "$HIDDEN_FILE"
  fi
}

# ─── Single source of truth: render the session picker menu ────
# $1 = 0|1  (whether to show the "Hidden" section)
render_sessions() {
  show_hidden="${1:-0}"

  sessions="$("$TMUX_BIN" list-sessions -F '#S' 2>/dev/null || true)"
  [ -z "$sessions" ] && return 0

  hidden_sessions="$(load_hidden_sessions)"

  # ---- active (non-hidden) sessions ----
  sessions="$(printf '%s\n' "$sessions" | LC_ALL=C sort -f)"
  case "${TMX_SORT_ORDER:-}" in
    recent)
      _sorted=""
      while IFS= read -r _sr; do
        [ -z "$_sr" ] && continue
        _act="$("$TMUX_BIN" display-message -t "$_sr" -p '#{session_activity}' 2>/dev/null || echo 0)"
        _sorted="${_sorted}${_act} ${_sr}\n"
      done <<EOF
$sessions
EOF
      sessions="$(printf '%b' "$_sorted" | LC_ALL=C sort -k1,1nr | cut -d' ' -f2-)"
      ;;
  esac
  while IFS= read -r s; do
    [ -z "$s" ] && continue
    if ! printf '%s\n' "$hidden_sessions" | grep -Fx "$s" >/dev/null 2>&1; then
      _w="$("$TMUX_BIN" list-windows -t "$s" 2>/dev/null | wc -l | tr -d ' ')"
      _c="$("$TMUX_BIN" list-clients -F '#{client_session}' 2>/dev/null | grep -Fxc "$s" | tr -d '\n' || echo 0)"
      _act="$("$TMUX_BIN" display-message -t "$s" -p '#{session_activity}' 2>/dev/null || echo 0)"
      _now="$(date +%s)"
      _diff=$(( _now - _act ))
      if [ "$_diff" -lt 60 ]; then
        _act="${_diff}s"
      elif [ "$_diff" -lt 3600 ]; then
        _act="$(( _diff / 60 ))m"
      elif [ "$_diff" -lt 86400 ]; then
        _act="$(( _diff / 3600 ))h"
      else
        _act="$(( _diff / 86400 ))d"
      fi
      if [ -n "${TMUX-}" ] && [ "$s" = "$("$TMUX_BIN" display-message -p '#S' 2>/dev/null)" ]; then
        printf '\033[38;2;166;227;161m● %s  \033[0m\033[38;2;166;173;200m%sw %sc  %s\033[0m\n' "$s" "$_w" "$_c" "$_act"
      elif [ "$_c" -gt 0 ] 2>/dev/null; then
        printf '\033[38;2;249;226;175m◎ %s  \033[0m\033[38;2;166;173;200m%sw %sc  %s\033[0m\n' "$s" "$_w" "$_c" "$_act"
      else
        printf '%s  \033[38;2;166;173;200m%sw %sc  %s\033[0m\n' "$s" "$_w" "$_c" "$_act"
      fi
    fi
  done <<EOF
$sessions
EOF

  # ---- hidden section (only when toggled on) ----
  if [ "$show_hidden" = "1" ]; then
    hidden_list=""
    while IFS= read -r s; do
      if printf '%s\n' "$hidden_sessions" | grep -Fx "$s" >/dev/null 2>&1; then
        hidden_list="${hidden_list}${s}
"
      fi
    done <<EOF
$sessions
EOF

    if [ -n "$hidden_list" ]; then
      printf '\033[1;90m━━━ Hidden (press ctrl-a to hide) ━━━\033[0m\n'
      printf '%s' "$hidden_list" | sed 's/^/        /'
    fi
  fi
}

# ─── Preview helper ────────────────────────────────────────────

# Render pane contents for a given session:window.
# $1 = session, $2 = window_index, $3 = pane_count
_render_panes() {
  if [ "$3" -eq 1 ]; then
    _first="$("$TMUX_BIN" list-panes -t "$1:$2" -F '#{pane_index}' 2>/dev/null | head -1)"
    "$TMUX_BIN" capture-pane -ep -t "$1:$2.$_first" -S 0 2>/dev/null \
      || echo "  (no content)"
  else
    "$TMUX_BIN" list-panes -t "$1:$2" \
      -F '#{pane_index}|#{pane_active}' 2>/dev/null | while IFS='|' read -r _pi _pa; do
      if [ "$_pa" = "1" ]; then
        printf '  \033[38;2;250;179;135m┌─ Pane %s (active) ─\033[0m\n' "$_pi"
      else
        printf '  \033[38;2;88;91;112m┌─ Pane %s ─\033[0m\n' "$_pi"
      fi
      "$TMUX_BIN" capture-pane -ep -t "$1:$2.$_pi" -S 0 -E 15 2>/dev/null \
        | sed 's/^/  │ /' || echo '  │ (no content)'
      printf '  └─────────────\n'
    done
  fi
}

# Summarize running processes across all session panes.
# Output: "nvim cargo zsh" or empty if nothing interesting.
preview_session() {
  s="$1"
  case "$s" in
    *━━━*)
      printf "Hidden sessions — ctrl-a to hide, ctrl-h to hide/unhide, r to rename, ctrl-x to kill\n"
      ;;
    *)
      s="$(clean_sel "$s")"
      # Git branch
      _panedir="$("$TMUX_BIN" display-message -t "$s" -p '#{pane_current_path}' 2>/dev/null)"
      _branch="$(git -C "$_panedir" branch --show-current 2>/dev/null || true)"
      [ -n "$_branch" ] && printf '\033[38;2;203;166;247m⎇ %s\033[0m\n' "$_branch"
      # Process summary — key processes running in all panes
      _running="$("$TMUX_BIN" list-panes -t "$s" -F '#{pane_pid}' 2>/dev/null | while IFS= read -r _pp; do
        pgrep -P "$_pp" 2>/dev/null | head -3 | while read -r _cp; do
          ps -o comm= -p "$_cp" 2>/dev/null
        done
      done | sort -u | head -10 | tr '\n' ' ' | sed 's/ $//')"
      [ -n "$_running" ] && printf '\033[38;2;148;226;213m▸ %s\033[0m\n' "$_running"
      # Session description
      if [ -f "$NOTES_FILE" ]; then
        _desc="$(grep -F "$s"$'\t' "$NOTES_FILE" 2>/dev/null | cut -f2-)"
        [ -n "$_desc" ] && printf '\033[38;2;250;179;135m%s\033[0m\n' "$_desc"
      fi

      "$TMUX_BIN" list-windows -t "$s" \
        -F "#{window_index}|#{window_name}|#{window_active}|#{window_panes}" \
        2>/dev/null | while IFS='|' read -r idx name active panes; do
        if [ "$active" = "1" ]; then
          printf '\033[38;2;166;227;161m━━━ Window %s: %s (active) ━━━\033[0m\n' "$idx" "$name"
        else
          printf '\033[38;2;203;166;247m━━━ Window %s: %s ━━━\033[0m\n' "$idx" "$name"
        fi
        _render_panes "$s" "$idx" "$panes"
        printf '\n'
      done || echo "No windows or session not found."
      ;;
  esac
}

# ─── Attach helpers ────────────────────────────────────────────

IN_TMUX=0
[ "${TMUX-}" ] && IN_TMUX=1

attach_normal() {
  if [ "$IN_TMUX" -eq 1 ]; then
    "$TMUX_BIN" switch-client -t "$1"
  else
    "$TMUX_BIN" attach-session -t "$1"
  fi
}

attach_detach_others() {
  if [ "$IN_TMUX" -eq 1 ]; then
    "$TMUX_BIN" detach-client -a -s "$1" 2>/dev/null || true
    "$TMUX_BIN" switch-client -t "$1"
  else
    "$TMUX_BIN" attach-session -d -t "$1"
  fi
}

# ─── Directory scanner / picker ─────────────────────────────────

scan_dirs() {
  _exclude="${TMX_EXCLUDE_PATHS:-node_modules|__pycache__|.git|target|dist}"
  _args="-maxdepth ${TMX_SCAN_DEPTH:-3} -type d -not -path '*/\..*'"
  # Build -not -path args for each exclude pattern
  _oldIFS="$IFS"
  IFS='|'
  for _pat in $_exclude; do
    [ -n "$_pat" ] && _args="$_args -not -path '*/$_pat/*'"
  done
  IFS="$_oldIFS"
  eval "find '$1' $_args 2>/dev/null" | sort
}

pick_directory() {
  _cache_file="${HOME}/.cache/tmx/dirs"
  _recent=""
  if [ -f "$_cache_file" ]; then
    _recent="$(cat "$_cache_file" 2>/dev/null)"
  fi

  home_dirs="$(scan_dirs "$HOME")"
  ext_dirs=""
  ext_header=""

  # macOS external volumes
  if [ -d /Volumes ]; then
    boot_vol="$(df / 2>/dev/null | awk 'NR==2{print $NF}')"
    for vol in /Volumes/*; do
      [ -d "$vol" ] || continue
      [ "$vol" = "$boot_vol" ] && continue
      vol_dirs="$(scan_dirs "$vol")"
      if [ -n "$vol_dirs" ]; then
        if [ -n "$ext_dirs" ]; then
          ext_dirs="$ext_dirs
$vol_dirs"
        else
          ext_dirs="$vol_dirs"
        fi
      fi
    done
    [ -n "$ext_dirs" ] && ext_header=" | External volumes included"
  # Linux external drives
  elif [ -d /mnt ] || [ -d /media ]; then
    for mnt in /mnt/* /media/*; do
      [ -d "$mnt" ] || continue
      mnt_dirs="$(scan_dirs "$mnt")"
      if [ -n "$mnt_dirs" ]; then
        if [ -n "$ext_dirs" ]; then
          ext_dirs="$ext_dirs
$mnt_dirs"
        else
          ext_dirs="$mnt_dirs"
        fi
      fi
    done
    [ -n "$ext_dirs" ] && ext_header=" | External drives included"
  fi

  # Build final list: recent dirs first, then home+external
  _input=""
  if [ -n "$_recent" ]; then
    _input="---recent---
$_recent"
  fi
  if [ -n "$ext_dirs" ]; then
    _input="$_input
$(printf '%s\n---external---\n%s' "$home_dirs" "$ext_dirs")"
  else
    _input="$_input
$home_dirs"
  fi

  dir="$(printf '%s\n' "$_input" | \
  fzf --height=90% --layout=reverse --border \
      --prompt='dir> ' --info=inline \
      --header="Enter: select | Esc: use current dir ($(pwd))${ext_header}" \
      --preview "$SCRIPT --internal-preview-dir {}" \
      --preview-window=right,50%,border-left \
      --bind 'change:reload-sync(printf "%s\n" "$_input")' || true)"
  # Reject sentinel lines — treat as Esc (use current dir)
  case "$dir" in ---external---|'') dir="" ;; esac
  case "$dir" in ---recent---) dir="" ;; esac
  printf '%s\n' "$dir"
}

# ─── Create new session ────────────────────────────────────────

create_session() {
  printf 'New session name: ' >/dev/tty
  IFS= read -r name </dev/tty || name=
  name="$(printf '%s' "$name" | awk '{$1=$1;print}')"
  [ -z "$name" ] && { printf 'Aborted: empty name.\n' >/dev/tty; exit 1; }

  dir="$(pick_directory)"
  [ -z "$dir" ] && dir="$PWD"

  # Save to recent-dirs cache
  _cache="${HOME}/.cache/tmx"
  mkdir -p "$_cache" 2>/dev/null
  _cache_file="$_cache/dirs"
  if [ -f "$_cache_file" ]; then
    grep -Fxv "$dir" "$_cache_file" > "$_cache_file.tmp" 2>/dev/null || true
    printf '%s\n' "$dir" | cat - "$_cache_file.tmp" 2>/dev/null | head -n "${TMX_RECENT_DIRS_MAX:-50}" > "$_cache_file"
    rm -f "$_cache_file.tmp"
  else
    printf '%s\n' "$dir" > "$_cache_file"
  fi

  "$TMUX_BIN" new-session -ds "$name" -c "$dir"
  attach_normal "$name"
}

# ─── Internal dispatch (called by fzf reload / execute binds) ──
# These run BEFORE set -eu so reloads never hit spurious failures.

case "${1:-}" in

  --help|-h)
    printf '%s\n' "tmx — tmux session picker via fzf"
    printf '%s\n' ""
    printf '%s\n' "  j/k: up/down  g/G: top/bottom  /: search  Esc: exit search  q: quit"
    printf '%s\n' "  Enter: attach   Ctrl-d: attach+detach   r: rename"
    printf '%s\n' "  Ctrl-h: hide/unhide   Ctrl-a: toggle hidden   Ctrl-x: kill"
    printf '%s\n' "  Ctrl-e: edit description   Ctrl-w: window view (Esc to return)"
    printf '%s\n' ""
    printf '%s\n' "Config: ~/.tmxrc (sourced as shell)"
    printf '%s\n' "  TMX_SCAN_DEPTH=3          find depth for dir picker"
    printf '%s\n' "  TMX_EXCLUDE_PATHS='...'    pipe-separated dirs to skip"
    printf '%s\n' "  TMX_SORT_ORDER=alpha        alpha|recent"
    printf '%s\n' "  TMX_PREVIEW_WINDOW='right,75%,border-left,wrap'"
    printf '%s\n' "  TMX_NERD_FONTS=0            force ASCII glyphs"
    exit 0
    ;;

  # usage:  tmx --internal-render <show-hidden-flag-file>
  --internal-render)
    flag_file="$2"
    show="$(cat "$flag_file" 2>/dev/null || echo 0)"
    render_sessions "$show"
    exit 0
    ;;

  # usage:  tmx --internal-toggle-display <show-hidden-flag-file>
  --internal-toggle-display)
    flag_file="$2"
    current="$(cat "$flag_file" 2>/dev/null || echo 0)"
    if [ "$current" = "1" ]; then
      printf '0' > "$flag_file"
      render_sessions 0
    else
      printf '1' > "$flag_file"
      render_sessions 1
    fi
    exit 0
    ;;

  # usage:  tmx --internal-rename <session-name>
  --internal-rename)
    session="$(clean_sel "$2")"
    skip_header "$session" || exit 0

    printf 'Rename "%s" to: ' "$session" >/dev/tty
    IFS= read -r newname </dev/tty || newname=
    newname="$(printf '%s' "$newname" | awk '{$1=$1;print}')"
    [ -z "$newname" ] && exit 0

    "$TMUX_BIN" rename-session -t "$session" "$newname"

    if grep -Fxq "$session" "$HIDDEN_FILE" 2>/dev/null; then
      grep -Fxv "$session" "$HIDDEN_FILE" > "${HIDDEN_FILE}.tmp" 2>/dev/null || true
      printf '%s\n' "$newname" >> "${HIDDEN_FILE}.tmp"
      mv "${HIDDEN_FILE}.tmp" "$HIDDEN_FILE"
    fi
    exit 0
    ;;

  # usage:  tmx --internal-toggle-hidden <session-name>
  --internal-toggle-hidden)
    session="$(clean_sel "$2")"
    skip_header "$session" || exit 0
    toggle_hidden "$session"
    exit 0
    ;;

  # usage:  tmx --internal-kill-session <session-name>
  --internal-kill-session)
    session="$(clean_sel "$2")"
    skip_header "$session" || exit 0

    printf 'Kill session "%s"? [y/N] ' "$session" >/dev/tty
    IFS= read -r ans </dev/tty || exit 0
    case "$ans" in [yY]|[yY][eE][sS]) ;; *) exit 0 ;; esac

    "$TMUX_BIN" kill-session -t "$session"

    if grep -Fxq "$session" "$HIDDEN_FILE" 2>/dev/null; then
      grep -Fxv "$session" "$HIDDEN_FILE" > "${HIDDEN_FILE}.tmp" 2>/dev/null || true
      mv "${HIDDEN_FILE}.tmp" "$HIDDEN_FILE"
    fi
    exit 0
    ;;

  # usage:  tmx --internal-new-session
  --internal-new-session)
    # Run create_session inline (prompts for name, picks dir, attaches)
    create_session
    exit 0
    ;;

  # usage:  tmx --internal-help
  --internal-help)
    printf '\033[38;2;137;220;235m━━━ Keybindings ━━━\033[0m\n\n'
    printf '\033[38;2;166;227;161mj / k\033[0m          Move down / up\n'
    printf '\033[38;2;166;227;161mg / G\033[0m          Jump to top / bottom\n'
    printf '\033[38;2;166;227;161m/\033[0m              Search\n'
    printf '\033[38;2;166;227;161mEsc\033[0m            Exit search / return from help\n'
    printf '\033[38;2;166;227;161m?\033[0m              Toggle this help\n'
    printf '\033[38;2;166;227;161mq\033[0m              Quit\n\n'
    printf '\033[38;2;166;227;161mEnter\033[0m          Attach to session\n'
    printf '\033[38;2;166;227;161mCtrl-n\033[0m         Create new session\n'
    printf '\033[38;2;166;227;161mCtrl-d\033[0m         Attach & detach others\n'
    printf '\033[38;2;166;227;161mCtrl-w\033[0m         Window view (Esc to return)\n'
    printf '\033[38;2;166;227;161mr\033[0m              Rename session\n'
    printf '\033[38;2;166;227;161mCtrl-h\033[0m         Toggle hide/unhide\n'
    printf '\033[38;2;166;227;161mCtrl-a\033[0m         Toggle hidden sessions\n'
    printf '\033[38;2;166;227;161mCtrl-x\033[0m         Kill session\n'
    printf '\033[38;2;166;227;161mCtrl-e\033[0m         Edit description\n'
    exit 0
    ;;

  # usage:  tmx --internal-set-description <session-name>
  --internal-set-description)
    session="$(clean_sel "$2")"
    skip_header "$session" || exit 0

    printf 'Description for "%s": ' "$session" >/dev/tty
    IFS= read -r desc </dev/tty || desc=
    desc="$(printf '%s' "$desc" | awk '{$1=$1;print}')"

    if [ -f "$NOTES_FILE" ]; then
      grep -Fv "$session"$'\t' "$NOTES_FILE" > "${NOTES_FILE}.tmp" 2>/dev/null || true
      mv "${NOTES_FILE}.tmp" "$NOTES_FILE"
    fi
    [ -n "$desc" ] && printf '%s\t%s\n' "$session" "$desc" >> "$NOTES_FILE"
    exit 0
    ;;

  # usage:  tmx --internal-preview <session-name>
  --internal-preview)
    preview_session "${2:-}"
    exit 0
    ;;

  # usage:  tmx --internal-list-windows <session-name>
  --internal-list-windows)
    _s="$(clean_sel "$2")"
    skip_header "$_s" || exit 0
    # Mark that we're in window view so Esc can return to sessions
    printf 1 > "${TMX_STATE_FILE}.win"
    # Store session name for preview handler
    printf '%s' "$_s" > "${TMX_STATE_FILE}.winsession"
    printf '← Back to sessions (Esc)\n'
    "$TMUX_BIN" list-windows -t "$_s" -F '#{window_index}|#{window_name}|#{window_active}' 2>/dev/null | while IFS='|' read -r _idx _wname _wact; do
      if [ "$_wact" = "1" ]; then
        printf '\033[38;2;166;227;161m● %s: %s (active)\033[0m\n' "$_idx" "$_wname"
      else
        printf '  %s: %s\n' "$_idx" "$_wname"
      fi
    done
    exit 0
    ;;

  # usage:  tmx --internal-preview-window <window-line>
  --internal-preview-window)
    _s="$(cat "${TMX_STATE_FILE}.winsession" 2>/dev/null || echo '')"
    [ -z "$_s" ] && exit 0
    _win="$(printf '%s' "$2" | sed 's/^[● ]*//; s/:.*//')"
    [ -z "$_win" ] && exit 0
    # Show single window preview — reuse preview_session logic scoped to one window
    "$TMUX_BIN" list-windows -t "$_s" -F "#{window_index}|#{window_name}|#{window_active}|#{window_panes}" 2>/dev/null | while IFS='|' read -r _idx _wname _wact _wpanes; do
      [ "$_idx" = "$_win" ] || continue
      if [ "$_wact" = "1" ]; then
        printf '\033[38;2;166;227;161m━━━ Window %s: %s (active) ━━━\033[0m\n' "$_idx" "$_wname"
      else
        printf '\033[38;2;203;166;247m━━━ Window %s: %s ━━━\033[0m\n' "$_idx" "$_wname"
      fi
      _render_panes "$_s" "$_idx" "$_wpanes"
    done
    exit 0
    ;;

  # usage:  tmx --internal-preview-dir <path>
  --internal-preview-dir)
    _d="$2"
    printf '\033[1m%s\033[0m\n' "$_d"
    # Git info
    _br="$(git -C "$_d" branch --show-current 2>/dev/null || true)"
    if [ -n "$_br" ]; then
      printf '\n\033[38;2;203;166;247m⎇ %s\033[0m\n' "$_br"
      git -C "$_d" status --short 2>/dev/null | head -20
    fi
    printf '\n'
    # File count + last modified
    _fcnt="$(ls -1 "$_d" 2>/dev/null | wc -l | tr -d ' ')"
    printf '%s files\n' "$_fcnt"
    ls -lt "$_d" 2>/dev/null | head -6
    exit 0
    ;;

esac

# ═══════════════════════════════════════════════════════════════
#  Main script
# ═══════════════════════════════════════════════════════════════

set -eu

# Guard: if we somehow reach main with args, bail silently (fzf reload races, etc.)
[ $# -eq 0 ] || exit 0

# ─── Config defaults (overridden by ~/.tmxrc if present) ──────
TMX_SCAN_DEPTH="${TMX_SCAN_DEPTH:-3}"
TMX_EXCLUDE_PATHS="${TMX_EXCLUDE_PATHS:-node_modules|__pycache__|.git|target|dist}"
TMX_SORT_ORDER="${TMX_SORT_ORDER:-alpha}"
TMX_PREVIEW_WINDOW="${TMX_PREVIEW_WINDOW:-right,75%,border-left,wrap}"
TMX_RECENT_DIRS_MAX="${TMX_RECENT_DIRS_MAX:-50}"
[ -f "${HOME}/.tmxrc" ] && . "${HOME}/.tmxrc"

need() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '%s\n' "$1 not found. Install it and try again.\n" >&2
    exit 127
  }
}
need tmux
need fzf

# Secure temp file for the show-hidden toggle (no predictable /tmp path)
SHOW_HIDDEN_FILE="$(mktemp)"
TMX_STATE_FILE="$SHOW_HIDDEN_FILE"
export TMX_STATE_FILE
trap 'rm -f "$SHOW_HIDDEN_FILE" "${SHOW_HIDDEN_FILE}.win"' EXIT
printf '0' > "$SHOW_HIDDEN_FILE"

# ─── Run fzf ───────────────────────────────────────────────────

SEL="$(
  render_sessions 0 | fzf \
    --height=90% --layout=reverse --border \
    --prompt='tmux> ' --info=inline --ansi \
    --expect=enter,ctrl-d,ctrl-n \
    --header='' \
    --bind 'start:disable-search' \
    --bind 'j:down,k:up,g:first,G:last,q:abort' \
    --bind '/:unbind(j,k,g,G,q,r)+enable-search+clear-query+change-prompt(search> )' \
    --bind "esc:reload-sync($SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\")+rebind(j,k,g,G,q,r)+disable-search+clear-query+change-prompt(tmux> )+change-preview($SCRIPT --internal-preview {})" \
    --bind "r:execute($SCRIPT --internal-rename {})+reload($SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\")" \
    --bind "ctrl-n:execute($SCRIPT --internal-new-session)+reload($SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\")" \
    --bind "?:execute-silent(if [ -f \"$SHOW_HIDDEN_FILE.help\" ]; then rm -f \"$SHOW_HIDDEN_FILE.help\"; else printf 1 > \"$SHOW_HIDDEN_FILE.help\"; fi)+reload-sync(if [ -f \"$SHOW_HIDDEN_FILE.help\" ]; then echo; else $SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\"; fi)+change-preview(if [ -f \"$SHOW_HIDDEN_FILE.help\" ]; then $SCRIPT --internal-help; else $SCRIPT --internal-preview {}; fi)" \
    --bind "ctrl-a:reload($SCRIPT --internal-toggle-display \"$SHOW_HIDDEN_FILE\")" \
    --bind "ctrl-h:execute-silent($SCRIPT --internal-toggle-hidden {})+reload($SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\")" \
    --bind "ctrl-x:execute($SCRIPT --internal-kill-session {})+reload($SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\")" \
    --bind "ctrl-e:execute($SCRIPT --internal-set-description {})+reload($SCRIPT --internal-render \"$SHOW_HIDDEN_FILE\")" \
    --bind "ctrl-w:reload($SCRIPT --internal-list-windows {})+change-preview($SCRIPT --internal-preview-window {})" \
    --preview "$SCRIPT --internal-preview {}" \
    --preview-window="${TMX_PREVIEW_WINDOW:-right,75%,border-left,wrap}" || true
)"

# ─── Parse fzf result ──────────────────────────────────────────

KEY="$(printf '%s' "${SEL}" | sed -n '1p')"
CHOICE="$(printf '%s' "${SEL}" | sed -n '$p')"
[ -z "${CHOICE}" ] && exit 0

# Strip leading spaces (from hidden-section indenting)
CHOICE="$(clean_sel "$CHOICE")"

# Skip section headers and leftovers (fzf may emit noise on exit)
case "${CHOICE}" in
  *━━━*|[eE][xX][iI][tT][eE][dD]*) exit 0 ;;
  '')
    # Esc pressed while in window view — re-run with session list
    if [ -f "${SHOW_HIDDEN_FILE}.win" ]; then
      rm -f "${SHOW_HIDDEN_FILE}.win"
      exec "$SCRIPT"
    fi
    exit 0
    ;;
esac

# ─── Route selection ───────────────────────────────────────────

# Window jumping: selection looks like "1: main (active)"
case "$CHOICE" in
  ←*)
    # Esc pressed on Back header — re-run sessions
    exec "$SCRIPT"
    ;;
  [0-9]*:*)
    _win="$(printf '%s' "$CHOICE" | sed 's/[: ].*//')"
    _parent="$("$TMUX_BIN" list-windows -F '#{session_name}|#{window_index}' 2>/dev/null | grep "|$_win$" | cut -d'|' -f1 | head -1)"
    [ -n "$_parent" ] && attach_normal "$_parent:$_win"
    exit 0
    ;;
esac

case "$KEY" in
  ctrl-d) attach_detach_others "$CHOICE" ;;
  ctrl-n) create_session ;;
  ""|enter|*) attach_normal "$CHOICE" ;;
esac
