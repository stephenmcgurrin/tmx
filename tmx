#!/usr/bin/env sh
# tmx: pick or create a tmux session via fzf, then attach/switch.
# deps: tmux, fzf
# license: MIT
TMUX_BIN="$(command -v tmux)"
HIDDEN_FILE="${HOME}/.tmx-hidden-sessions"
set -eu

need() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '%s\n' "$1 not found. Install it and try again.\n" >&2
    exit 127
  }
}
need tmux
need fzf

# Load hidden sessions into memory
load_hidden_sessions() {
  [ -f "$HIDDEN_FILE" ] && cat "$HIDDEN_FILE" || true
}

# Check if a session is hidden
is_hidden() {
  session="$1"
  hidden_sessions="$(load_hidden_sessions)"
  printf '%s\n' "$hidden_sessions" | grep -Fx "$session" >/dev/null 2>&1
}

# Toggle a session's hidden state
toggle_hidden() {
  session="$1"
  if is_hidden "$session"; then
    # Unhide: remove from file
    if [ -f "$HIDDEN_FILE" ]; then
      grep -Fxv "$session" "$HIDDEN_FILE" > "${HIDDEN_FILE}.tmp" 2>/dev/null || true
      mv "${HIDDEN_FILE}.tmp" "$HIDDEN_FILE"
    fi
  else
    # Hide: add to file
    printf '%s\n' "$session" >> "$HIDDEN_FILE"
  fi
}

# list sessions; show a virtual "create" row first
SESSIONS="$(tmux list-sessions -F '#S' 2>/dev/null || true)"

# Build menu with Active and Hidden sections
menu() {
  printf '%s\n' "[+ ] Create new session"

  if [ -n "${SESSIONS}" ]; then
    hidden_sessions="$(load_hidden_sessions)"
    active_sessions=""
    hidden_list=""

    # Categorize sessions
    while IFS= read -r session; do
      if printf '%s\n' "$hidden_sessions" | grep -Fx "$session" >/dev/null 2>&1; then
        hidden_list="${hidden_list}${session}"$'\n'
      else
        active_sessions="${active_sessions}${session}"$'\n'
      fi
    done <<EOF
$SESSIONS
EOF

    # Print Active Sessions section
    if [ -n "$active_sessions" ]; then
      printf '\033[1;36m━━━ Active Sessions ━━━\033[0m\n'
      printf '%s' "$active_sessions"
    fi

    # Print Hidden Sessions section
    if [ -n "$hidden_list" ]; then
      printf '\033[1;90m━━━ Hidden Sessions ━━━\033[0m\n'
      printf '%s' "$hidden_list"
    fi
  fi
}

SEL="$(
  menu | fzf --height=90% --layout=reverse --border \
             --prompt='tmux> ' --info=inline --ansi \
             --expect=enter,ctrl-d \
             --header='Enter: attach | Ctrl-d: attach+detach others | Ctrl-h: toggle hide' \
             --bind "ctrl-h:execute-silent(
               session={}
               # Skip action if it's a header line or create option
               case \"\$session\" in
                 *━━━*|''[+\ ]*) exit 0 ;;
               esac
               # Toggle hidden state
               if grep -Fxq \"\$session\" '$HIDDEN_FILE' 2>/dev/null; then
                 grep -Fxv \"\$session\" '$HIDDEN_FILE' > '${HIDDEN_FILE}.tmp' 2>/dev/null || true
                 mv '${HIDDEN_FILE}.tmp' '$HIDDEN_FILE'
               else
                 printf '%s\n' \"\$session\" >> '$HIDDEN_FILE'
               fi
             )+reload(
               printf '%s\n' '[+ ] Create new session'
               SESSIONS=\$(tmux list-sessions -F '#S' 2>/dev/null || true)
               if [ -n \"\$SESSIONS\" ]; then
                 hidden_sessions=\$([ -f '$HIDDEN_FILE' ] && cat '$HIDDEN_FILE' || true)
                 active_sessions=\"\"
                 hidden_list=\"\"
                 while IFS= read -r session; do
                   if printf '%s\n' \"\$hidden_sessions\" | grep -Fx \"\$session\" >/dev/null 2>&1; then
                     hidden_list=\"\${hidden_list}\${session}\"\$'\n'
                   else
                     active_sessions=\"\${active_sessions}\${session}\"\$'\n'
                   fi
                 done <<EOF_INNER
\$SESSIONS
EOF_INNER
                 if [ -n \"\$active_sessions\" ]; then
                   printf '\033[1;36m━━━ Active Sessions ━━━\033[0m\n'
                   printf '%s' \"\$active_sessions\"
                 fi
                 if [ -n \"\$hidden_list\" ]; then
                   printf '\033[1;90m━━━ Hidden Sessions ━━━\033[0m\n'
                   printf '%s' \"\$hidden_list\"
                 fi
               fi
             )" \
             --preview '
               if [ {} = "'\''[+ ] Create new session'\''" ]; then
                 printf "Create a new tmux session in: %s\n\n" "$PWD"
                 printf "Press Enter to name it.\n"
               elif printf "%s" "{}" | grep -q "━━━"; then
                 printf "Section header - select a session below\n"
               else
                 # Show live preview of session windows and panes
                 session={}
                 '"$TMUX_BIN"' list-windows -t "$session" -F "#{window_index}|#{window_name}|#{window_active}|#{window_panes}" 2>/dev/null | while IFS="|" read -r idx name active pane_count; do
                   # Print window header
                   if [ "$active" = "1" ]; then
                     printf "\033[1;32m━━━ Window %s: %s (active) ━━━\033[0m\n" "$idx" "$name"
                   else
                     printf "\033[1;34m━━━ Window %s: %s ━━━\033[0m\n" "$idx" "$name"
                   fi

                   # Show panes for this window
                   if [ "$pane_count" -eq 1 ]; then
                     # Single pane - show full content (get first pane index dynamically)
                     first_pane="$('"$TMUX_BIN"' list-panes -t "$session:$idx" -F "#{pane_index}" 2>/dev/null | head -1)"
                     '"$TMUX_BIN"' capture-pane -ep -t "$session:$idx.$first_pane" -S 0 2>/dev/null || echo "  (no content)"
                   else
                     # Multiple panes - show them side by side or stacked
                     '"$TMUX_BIN"' list-panes -t "$session:$idx" -F "#{pane_index}|#{pane_active}|#{pane_width}|#{pane_height}|#{pane_left}|#{pane_top}" 2>/dev/null | while IFS="|" read -r pidx pactive pw ph pl pt; do
                       if [ "$pactive" = "1" ]; then
                         printf "  \033[1;33m┌─ Pane %s (active) ─\033[0m\n" "$pidx"
                       else
                         printf "  \033[0;37m┌─ Pane %s ─\033[0m\n" "$pidx"
                       fi
                       # Show visible content (top 15 lines) of each pane
                       '"$TMUX_BIN"' capture-pane -ep -t "$session:$idx.$pidx" -S 0 -E 15 2>/dev/null | sed "s/^/  │ /" || echo "  │ (no content)"
                       printf "  └─────────────\n"
                     done
                   fi
                   printf "\n"
                 done || echo "No windows or session not found."
               fi
             ' \
             --preview-window=right,75%,border-left,wrap || true
)"

KEY="$(printf '%s' "${SEL}" | sed -n '1p')"
CHOICE="$(printf '%s' "${SEL}" | sed -n '$p')"
[ -z "${CHOICE}" ] && exit 0

# Skip if user selected a section header
case "${CHOICE}" in
  *━━━*) exit 0 ;;
esac

IN_TMUX=0
[ "${TMUX-}" ] && IN_TMUX=1

attach_normal() {
  if [ "$IN_TMUX" -eq 1 ]; then
    tmux switch-client -t "$1"
  else
    tmux attach-session -t "$1"
  fi
}

attach_detach_others() {
  if [ "$IN_TMUX" -eq 1 ]; then
    tmux detach-client -a -s "$1" 2>/dev/null || true
    tmux switch-client -t "$1"
  else
    tmux attach-session -d -t "$1"
  fi
}

create_session() {
  # prompt on the real TTY so it works after fzf
  printf 'New session name: ' >/dev/tty
  IFS= read -r name </dev/tty || name=
  # trim spaces
  name="$(printf '%s' "$name" | awk '{$1=$1;print}')"
  [ -z "$name" ] && { printf 'Aborted: empty name.\n' >/dev/tty; exit 1; }

  # create detached so behaviour is identical inside/outside tmux
  # start in current working directory
  tmux new-session -ds "$name" -c "$PWD"

  # then attach/switch
  if [ "$IN_TMUX" -eq 1 ]; then
    tmux switch-client -t "$name"
  else
    tmux attach-session -t "$name"
  fi
}

# route selection
if [ "$CHOICE" = "[+ ] Create new session" ]; then
  create_session
  exit 0
fi

case "$KEY" in
  ctrl-d) attach_detach_others "$CHOICE" ;;
  ""|enter|*) attach_normal "$CHOICE" ;;
esac
